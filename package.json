{
  "name": "std-kit",
  "version": "2.4.1",
  "description": "NodeJS Standard Library Additions",
  "keywords": [
    "std",
    "standard",
    "library",
    "utilities",
    "node",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luastoned/std-kit.git"
  },
  "author": "LuaStoned <npm@luastoned.com>",
  "license": "MIT",
  "private": false,
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*"
  ],
  "scripts": {
    "build": "yarn clean && yarn build:tsup",
    "build:tsup": "tsup",
    "build:code": "tsc --project tsconfig.build.json",
    "build:types": "tsc --project tsconfig.build.json --declaration --emitDeclarationOnly",
    "clean": "rimraf coverage dist docs lib",
    "docs": "typedoc",
    "test": "vitest",
    "release": "release-it"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.15.23",
    "esbuild": "^0.25.5",
    "release-it": "^19.0.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typedoc": "^0.28.5",
    "typedoc-plugin-markdown": "^4.6.3",
    "typedoc-plugin-merge-modules": "^7.0.0",
    "typescript": "^5.8.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.4"
  }
}
