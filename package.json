{
  "name": "std-kit",
  "version": "2.8.0",
  "private": false,
  "description": "NodeJS Standard Library Additions",
  "keywords": [
    "library",
    "node",
    "standard",
    "std",
    "typescript",
    "utilities"
  ],
  "homepage": "https://github.com/luastoned/std-kit",
  "license": "MIT",
  "author": "LuaStoned <npm@luastoned.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luastoned/std-kit.git"
  },
  "files": [
    "lib"
  ],
  "main": "./lib/index.js",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.js"
    },
    "./node": {
      "types": "./lib/node.d.cts",
      "import": "./lib/node.mjs",
      "require": "./lib/node.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "yarn build:tsdown",
    "build:tsdown": "tsdown",
    "build:code": "tsc --project tsconfig.build.json",
    "build:types": "tsc --project tsconfig.build.json --declaration --emitDeclarationOnly",
    "clean": "rimraf coverage dist docs lib",
    "docs": "yarn docs:typedoc && yarn docs:transform",
    "docs:transform": "tsx scripts/transform-docs.ts",
    "docs:typedoc": "typedoc --excludeInternal --intentionallyNotExported KeySelector --intentionallyNotExported GetNestedField --intentionallyNotExported GetDirectOrIndexedField --json docs/documentation.json",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit",
    "release": "release-it",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "release-it": "^19.2.4",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.6",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
