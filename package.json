{
  "name": "std-kit",
  "version": "2.0.0",
  "description": "NodeJS Standard Library Additions",
  "keywords": [
    "std",
    "standard",
    "library",
    "utilities",
    "node",
    "typescript"
  ],
  "repository": "https://github.com/luastoned/std-kit",
  "author": "LuaStoned <npm@luastoned.com>",
  "license": "MIT",
  "private": false,
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*"
  ],
  "scripts": {
    "build": "yarn clean && yarn build:tsup",
    "build:tsup": "tsup",
    "build:code": "tsc --project tsconfig.build.json",
    "build:types": "tsc --project tsconfig.build.json --declaration --emitDeclarationOnly",
    "clean": "rimraf coverage dist docs lib",
    "docs": "typedoc",
    "release": "release-it"
  },
  "dependencies": {
    "deepmerge-ts": "^7.1.0",
    "merge-deep-ts": "^1.2.12",
    "ts-deepmerge": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.2",
    "esbuild": "^0.24.0",
    "release-it": "^17.6.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typedoc": "^0.26.7",
    "typedoc-plugin-markdown": "^4.2.8",
    "typedoc-plugin-merge-modules": "^6.0.1",
    "typescript": "^5.6.2"
  }
}
