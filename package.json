{
  "name": "std-kit",
  "version": "2.4.1",
  "description": "NodeJS Standard Library Additions",
  "keywords": [
    "std",
    "standard",
    "library",
    "utilities",
    "node",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luastoned/std-kit.git"
  },
  "author": "LuaStoned <npm@luastoned.com>",
  "license": "MIT",
  "private": false,
  "files": [
    "lib"
  ],
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": "./lib/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "yarn clean && yarn build:tsup",
    "build:tsup": "tsup",
    "build:tsdown": "tsdown",
    "build:code": "tsc --project tsconfig.build.json",
    "build:types": "tsc --project tsconfig.build.json --declaration --emitDeclarationOnly",
    "clean": "rimraf coverage dist docs lib",
    "docs": "typedoc",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "release-it"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.9.1",
    "esbuild": "^0.25.11",
    "release-it": "^19.0.5",
    "rimraf": "^6.0.1",
    "tsdown": "^0.15.10",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typedoc-plugin-merge-modules": "^7.0.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.4"
  }
}
